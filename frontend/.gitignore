```gitignore
# ======================
# Dependencies
# ======================
node_modules/
**/node_modules/

# ======================
# Environment Variables
# ======================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
**/.env

# ======================
# Logs
# ======================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ======================
# Runtime Data
# ======================
pids
*.pid
*.seed
*.pid.lock

# ======================
# Build Folders
# ======================
dist/
build/
**/dist/
**/build/

# ======================
# Coverage
# ======================
coverage/
.nyc_output/

# ======================
# Cache
# ======================
.cache/
.parcel-cache/
.vite/

# ======================
# Operating System Files
# ======================
.DS_Store
Thumbs.db
desktop.ini

# ======================
# IDE / Editor
# ======================
.vscode/
.idea/
*.swp
*.swo

# ======================
# Temporary Files
# ======================
tmp/
temp/

# ======================
# Uploads (Optional)
# ======================
uploads/

# ======================
# Database Files
# ======================
*.sqlite
*.sqlite3

# ======================
# Deployment
# ======================
.vercel
.netlify

# ======================
# Misc
# ======================
*.tgz
```
